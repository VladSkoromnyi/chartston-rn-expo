{
  "name": "chartston",
  "version": "0.1.0",
  "description": "GPU-accelerated interactive candlestick charting library for React Native / Expo (New Architecture, Skia + Reanimated)",
  "main": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "exports": {
    ".": {
      "chartston-source": "./src/index.tsx",
      "types": "./lib/typescript/src/index.d.ts",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "clean": "del-cli lib",
    "prepare": "bob build",
    "typecheck": "tsc -p tsconfig.build.json",
    "lint": "eslint src",
    "test": "vitest run",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bob build && changeset publish"
  },
  "keywords": [
    "react-native",
    "expo",
    "candlestick",
    "candlestick-chart",
    "chart",
    "charting",
    "trading",
    "trading-chart",
    "ohlc",
    "technical-analysis",
    "finance",
    "skia",
    "reanimated",
    "gpu",
    "new-architecture",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VladSkoromnyi/chartston-rn-expo.git"
  },
  "author": "Vlad Skoromnyi <vlad.skoromnyi.work@gmail.com> (https://github.com/VladSkoromnyi)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/VladSkoromnyi/chartston-rn-expo/issues"
  },
  "homepage": "https://github.com/VladSkoromnyi/chartston-rn-expo#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/compat": "^2.1.0",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@gorhom/bottom-sheet": "5.2.14",
    "@react-native/babel-preset": "0.85.0",
    "@react-native/eslint-config": "0.85.0",
    "@shopify/react-native-skia": "2.6.2",
    "@types/react": "^19.2.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.3",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-builder-bob": "^0.43.0",
    "react-native-gesture-handler": "2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-worklets": "0.8.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@gorhom/bottom-sheet": ">=5.0.0",
    "@shopify/react-native-skia": ">=2.0.0",
    "react": ">=19.0.0",
    "react-native": ">=0.79.0",
    "react-native-gesture-handler": ">=2.31.0",
    "react-native-reanimated": ">=4.0.0",
    "react-native-worklets": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "@gorhom/bottom-sheet": {
      "optional": true
    }
  },
  "packageManager": "yarn@4.11.0",
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "tools": [
      "eslint"
    ],
    "version": "0.63.0"
  }
}
